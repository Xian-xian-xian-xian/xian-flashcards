{
  "name": "xian-flashcards",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:remote": "HOST=0.0.0.0 node scripts/dev.mjs",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "NODE_ENV=production node dist-server/server/index.js",
    "start:remote": "HOST=0.0.0.0 NODE_ENV=production node dist-server/server/index.js",
    "remote": "pnpm build && pnpm start:remote",
    "deploy:ecs": "bash scripts/deploy-ecs.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0",
    "tsx": "^4.19.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
